# 복사해서 .env로 저장 후 실제 값 채우기. .env는 커밋하지 말 것(.gitignore에 이미 포함).

# CAPD 공유 Supabase Postgres. Session pooler 사용 권장
# (direct host는 IPv6 전용이라 일부 환경에서 접속 실패 — CLAUDE.md 인프라 메모 참고).
# 형식: postgresql://postgres.<project-ref>:<url-encoded-password>@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres
CAPD_DB_URL=

# Slack Incoming Webhook URL (없으면 비워둬도 됨 — 로그로만 알림 대체).
# 만드는 법: https://api.slack.com/apps -> Create New App -> From scratch
#           -> Incoming Webhooks 활성화 -> Add New Webhook to Workspace -> 채널 선택 -> URL 복사
SLACK_WEBHOOK_URL=
